# PostgreSQL connection string (see docker-compose.yml at repo root)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hqtovideo

# HTTP server port
PORT=3001

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=heroic-vision-storage
# optional: override for local MinIO (http://localhost:9000)
R2_ENDPOINT=
